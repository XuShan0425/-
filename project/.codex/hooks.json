{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_auto_pr.py\"",
            "timeout": 1200,
            "statusMessage": "Verifying changes and opening/updating Codex PR"
          }
        ]
      }
    ]
  }
}
